# Copy this file to secrets.yaml and fill in your own values.
# secrets.yaml is gitignored and must never be committed.
#
# Generate a fresh API encryption key with:
#   openssl rand -base64 32

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
api_encryption_key: "REPLACE_WITH_openssl_rand_base64_32"
ota_password: "REPLACE_WITH_A_STRONG_PASSWORD"
ap_password: "REPLACE_WITH_A_STRONG_PASSWORD"
